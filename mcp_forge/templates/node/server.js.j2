const BEARER_TOKEN = process.env.BEARER_TOKEN || "";
{%- elif scheme.is_api_key %}
// API key auth ({{ scheme.api_key_in }}: {{ scheme.api_key_name }}) – set the API_KEY environment variable.
const API_KEY = process.env.API_KEY || "";
{%- endif %}
{%- endfor %}
{%- else %}
// No security schemes detected in the OpenAPI spec.
