{%- endif %}
{%- endif %}

/**
 * Build HTTP headers required for authenticated requests.
 * @returns {Record<string, string>}
 */
function makeHeaders() {
  const headers = { "Content-Type": "application/json" };
{%- if include_auth and security_schemes %}
{%- for scheme in security_schemes %}
{%- if scheme.is_bearer %}
  if (BEARER_TOKEN) {
    headers["Authorization"] = `Bearer ${BEARER_TOKEN}`;
  }
{%- elif scheme.is_api_key and scheme.api_key_in == "header" %}
  if (API_KEY) {
    headers["{{ scheme.api_key_name }}"] = API_KEY;
  }
{%- endif %}
{%- endfor %}
{%- endif %}
